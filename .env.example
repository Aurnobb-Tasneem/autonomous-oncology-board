# ── ROCm / ML ──────────────────────────────────────────────────────────────
# HuggingFace token (required for GigaPath — gated model)
HF_TOKEN=hf_your_token_here

# Ollama host (from inside Docker container, bridge IP is usually 172.17.0.1)
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_MODEL=llama3.3:70b

# Qdrant local storage path (inside container)
QDRANT_PATH=/workspace/aob/data/qdrant

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Optional ─────────────────────────────────────────────────────────────────
# Set to INFO or DEBUG
LOG_LEVEL=INFO
