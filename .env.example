# ── ROCm / ML ──────────────────────────────────────────────────────────────
# HuggingFace token (required for GigaPath + Qwen2.5-VL — gated models)
HF_TOKEN=hf_your_token_here

# Ollama host as seen from inside the ROCm Docker container.
# bootstrap.sh auto-detects the correct Docker bridge gateway and writes it here.
# Override only if your Docker network setup is non-standard (custom bip=, rootless, etc.).
OLLAMA_HOST=http://172.17.0.1:11434
# FP16 70B (~140 GB weights) — matches hackathon “full precision” demo path
OLLAMA_MODEL=llama3.3:70b-instruct-fp16

# Qdrant local storage path (inside container)
QDRANT_PATH=/workspace/aob/data/qdrant

# ── Qwen-VL second-opinion pathologist ─────────────────────────────────────
# Independent vision-language model used as a second opinion alongside GigaPath.
QWEN_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ── vLLM Specialist Adapters (LoRA on Llama-3.1-8B) ────────────────────────
# Default: multi-LoRA hot-swap server with all three adapters on a single port.
# If multi-LoRA hot-swap is unstable on the current ROCm/vLLM build, run
# scripts/serve_specialists_fallback.sh (ports 8006/8007/8008) and update the
# URLs below accordingly.
SPECIALISTS_PORT=8006
TNM_VLLM_BASE_URL=http://localhost:8006/v1
BIOMARKER_VLLM_BASE_URL=http://localhost:8006/v1
TREATMENT_VLLM_BASE_URL=http://localhost:8006/v1

# ── API ─────────────────────────────────────────────────────────────────────
API_PORT=8000

# ── Frontend (Next.js 16) ──────────────────────────────────────────────────
# Used by the frontend at build/runtime to reach the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Job persistence ──────────────────────────────────────────────────────────
# Directory where completed job JSON files are written (survives API restarts).
# Excluded from git via .gitignore. Change to an absolute path if needed.
JOBS_DIR=data/jobs

# ── Optional ─────────────────────────────────────────────────────────────────
# Set to INFO or DEBUG
LOG_LEVEL=INFO
